# AI Interview Platform - Git Ignore File
# Prevent sensitive and unnecessary files from being committed

# Environment variables
.env
.env.local
.env.production

# Database
*.db
*.sqlite
*.sqlite3
database.db

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Flask
instance/
.webassets-cache

# Uploads
uploads/*
!uploads/.gitkeep

# IDEs
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Logs
*.log
logs/

# Testing
.coverage
.pytest_cache/
htmlcov/

# System Files
Thumbs.db
desktop.ini
